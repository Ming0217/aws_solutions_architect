# Copy to .env and fill in. NEVER commit the real .env (DB creds are NOT here —
# they're fetched from Secrets Manager at runtime; only the secret NAME is here).
S3_BUCKET=photoshare-images-<account-id>
AWS_SECRET_NAME=photoshare/db-credentials
AWS_REGION=us-east-1
# Shared secret gating POST /internal/metadata; must match the Lambda's env.
INTERNAL_API_KEY=change-me
